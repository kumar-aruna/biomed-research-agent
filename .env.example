# ── LLM Provider ─────────────────────────────────────────────────────────
# Options: OPENROUTER | GEMINI | AZURE_OPENAI
LLM_PROVIDER=AZURE_OPENAI

# ── OpenRouter (used when LLM_PROVIDER=OPENROUTER) ───────────────────────
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
# Planning model (tool-calling required). Free options: openai/gpt-oss-120b:free, nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Synthesis model (optional override — defaults to OPENROUTER_MODEL)
OPENROUTER_SYNTH_MODEL=openai/gpt-oss-120b:free

# ── Google Gemini (used when LLM_PROVIDER=GEMINI) ────────────────────────
# Get your API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Chat model — see https://ai.google.dev/gemini-api/docs/models
# Planning model — lite, high quota (many calls per query)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Synthesis model — more capable, called once per query
GEMINI_SYNTH_MODEL=gemini-3-flash-preview

# Embedding model
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Azure OpenAI (used when LLM_PROVIDER=AZURE_OPENAI) ───────────────────
# Get these from your Azure portal
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Chat model (GPT-4o recommended)
AZURE_OPENAI_LLM_MODEL=gpt-4o
AZURE_OPENAI_LLM_MODEL_DEPLOYMENT_ID=your-deployment-name

# Embedding model (used by app.py for optional ChromaDB features;
# the notebook's BM25 pipeline does not require embeddings)
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL_DEPLOYMENT_ID=your-embedding-deployment-name
