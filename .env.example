# Azure OpenAI — get these from your Azure portal
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Chat model (GPT-4o recommended)
AZURE_OPENAI_LLM_MODEL=gpt-4o
AZURE_OPENAI_LLM_MODEL_DEPLOYMENT_ID=your-deployment-name

# Embedding model (used by app.py for optional ChromaDB features;
# the notebook's BM25 pipeline does not require embeddings)
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL_DEPLOYMENT_ID=your-embedding-deployment-name
